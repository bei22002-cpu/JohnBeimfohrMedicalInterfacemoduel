# Build from repository root: docker build -f infra/Dockerfile.web .
FROM node:20-alpine AS build
WORKDIR /app
ARG VITE_FLEET_API_URL=
ARG VITE_ROOM_ID=room-docker
ARG VITE_CONTENT_VERSION=1.0.0
ARG VITE_USE_MEDICAL_ASR=0
ENV VITE_FLEET_API_URL=$VITE_FLEET_API_URL
ENV VITE_ROOM_ID=$VITE_ROOM_ID
ENV VITE_CONTENT_VERSION=$VITE_CONTENT_VERSION
ENV VITE_USE_MEDICAL_ASR=$VITE_USE_MEDICAL_ASR
COPY package.json ./
RUN npm install
COPY index.html vite.config.ts tsconfig.json tsconfig.node.json ./
COPY src ./src
RUN npm run build

FROM nginx:1.27-alpine
COPY infra/nginx/default.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
