# Client (Vite) — copy to .env.local for local dev
VITE_FLEET_API_URL=http://localhost:3001
VITE_ROOM_ID=room-101
VITE_CONTENT_VERSION=1.0.0
# Set to 1 to use MediaRecorder + fleet-api + Azure Speech (server-side)
VITE_USE_MEDICAL_ASR=0

# Fleet API (docker / node)
# PORT=3001
# CORS_ORIGINS=http://localhost:5173,http://localhost:8080
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=
# CONTENT_VERSION=1.0.0
# HIPAA_MINIMAL_LOGGING=1
# DATA_DIR=./data
